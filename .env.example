MIMIC_ROOT=/data/mimiciv
MIMIC_NOTE_ROOT=/data/mimiciv_note

# Hugging Face: store models and hub cache on large disk (not ~/.cache)
HF_HOME=/data/Amin

# Local LLM/RAG baselines (single GPU). Default fits comfortably on one H100/A100-class GPU.
TRIGGERBENCH_HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
# Use cuda:1 when GPU 0 is busy (e.g. other jobs); cuda:0 on single-GPU workstations.
TRIGGERBENCH_CUDA_DEVICE=cuda:1

# Set to 1 only when the model is downloaded and you want pytest + real-data to run HF baselines (requires CUDA).
# TRIGGERBENCH_RUN_HF_TESTS=1

# Optional: cloud API for Phase 9 agent experiments (not used by local HF baselines).
# GEMINI_API_KEY=
